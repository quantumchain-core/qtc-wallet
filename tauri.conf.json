{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "QTC Wallet",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "open": false },
      "clipboard": { "writeText": true, "readText": false }
    },
    "bundle": {
      "active": true,
      "category": "Finance",
      "copyright": "QuantumChain Foundation",
      "deb": { "depends": [] },
      "externalBin": [],
      "icon": ["icons/32x32.png", "icons/128x128.png"],
      "identifier": "network.qtc.wallet",
      "longDescription": "Post-quantum secure QTC desktop wallet",
      "macOS": {},
      "resources": [],
      "shortDescription": "QTC Wallet",
      "targets": "all",
      "windows": { "certificateThumbprint": null, "digestAlgorithm": "sha256", "timestampUrl": "" }
    },
    "security": {
      "csp": "default-src 'self'; connect-src http://localhost:8545 https://*.qtc.network"
    },
    "updater": { "active": false },
    "windows": [
      {
        "fullscreen": false,
        "height": 680,
        "resizable": true,
        "title": "QTC Wallet",
        "width": 420
      }
    ]
  }
}
